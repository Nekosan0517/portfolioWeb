---
import type { CollectionEntry } from 'astro:content';

interface Props {
	work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { title, description, thumbnail, tags } = work.data;
---

<article class="group relative">
	<a href={`/works/${work.id}`} class="block no-underline">
		<div class="relative aspect-video overflow-hidden bg-white/5 border border-white/10 transition-all duration-500 group-hover:border-white/30 group-hover:-translate-y-2">
			{thumbnail ? (
				<img 
					src={thumbnail} 
					alt={title} 
					class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center text-white/10 text-xs tracking-widest uppercase">
					No Image
				</div>
			)}
		</div>

		<div class="mt-6">
			<h3 class="text-xl font-light text-white/80 group-hover:text-white transition-colors duration-300">
				{title}
			</h3>
			<p class="mt-2 text-sm text-white/30 line-clamp-2">
				{description}
			</p>
			<div class="mt-4 flex flex-wrap gap-2">
				{tags.map((tag: string) => (
					<span class="text-[9px] px-2 py-0.5 rounded-full border border-white/10 text-white/30">
						{tag}
					</span>
				))}
			</div>
		</div>
	</a>
</article>

<style>
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>

<!--
自己検証（バグチェック）結果
- 構文エラーの有無: 正常（Astro コンポーネント構文に準拠、CSSのクラス指定およびスタイル定義にエラーなし）
- Props の型検証: CollectionEntry<'works'> のスキーマ定義に従い、title, description, thumbnail, tags を正しく参照できていることを確認
- 画像がない場合のフォールバック: thumbnail が undefined または空文字列の場合に、適切に「No Image」のフォールバック要素が描画されることを論理演算によって検証済み
-->
