---
/**
 * HeroSection コンポーネント
 * profile.json の hero データを受け取り、ページ最上部に表示する
 * 氏名・英語名・キャッチコピーを大きなタイポグラフィで表現する
 */

interface Props {
  /** ヒーローセクション表示データ（profile.json の hero フィールド） */
  hero: {
    nameJa: string;
    nameEn: string;
    catchcopy: string;
  };
  /** プロフィール画像のURL */
  profileImage: string;
}

const { hero, profileImage } = Astro.props;
---

<section class="hero-section" aria-label="ヒーロー">
  <!-- 背景装飾: ラジアルグラデーション -->
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="hero-content">
    <!-- プロフィール画像 -->
    <div class="hero-image-wrap" data-reveal data-reveal-delay="0">
      <div class="hero-image-frame">
        <img
          src={profileImage}
          alt="嶺田拓磨のプロフィールイラスト"
          class="hero-image"
          loading="eager"
          decoding="async"
          width="400"
          height="400"
        />
      </div>
    </div>

    <!-- キャッチコピー -->
    <p class="hero-catchcopy" data-reveal data-reveal-delay="150">
      {hero.catchcopy}
    </p>

    <!-- 日本語名 -->
    <h1 class="hero-name-ja" data-reveal data-reveal-delay="280">
      {hero.nameJa}
    </h1>

    <!-- 英語名 -->
    <p class="hero-name-en" data-reveal data-reveal-delay="380">
      {hero.nameEn}
    </p>
  </div>
</section>

<style>
  /* ヒーローセクション全体レイアウト */
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }

  /* 背景ラジアルグラデーション装飾 */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 40%, rgba(179, 108, 52, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 20% 70%, rgba(150, 118, 97, 0.06) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ヒーローコンテンツ配置 */
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
    width: 100%;
  }

  /* キャッチコピー */
  .hero-catchcopy {
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    font-weight: 400;
    letter-spacing: 0.25em;
    color: var(--accent-color);
    text-transform: uppercase;
    margin: 0;
    font-family: 'Inter', sans-serif;
  }

  /* 日本語氏名（メイン見出し） */
  .hero-name-ja {
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 200;
    letter-spacing: -0.02em;
    color: var(--text-main);
    margin: 0;
    line-height: 1;
    font-family: 'Noto Serif JP', 'Georgia', serif;
  }

  /* 英語名 */
  .hero-name-en {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin: 0;
    font-family: 'Inter', sans-serif;
  }

  /* プロフィール画像ラッパー */
  .hero-image-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  /* プロフィール画像フレーム */
  .hero-image-frame {
    width: 70vw;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    padding: 0.8rem;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.15);
  }

  /* プロフィール画像 */
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>

<script>
  /**
   * プロフィール画像の最大幅を元解像度とデザイン上限値から動的に調整する処理
   */
  function adjustImageMaxSize() {
    const img = document.querySelector('.hero-image') as HTMLImageElement;
    const frame = document.querySelector('.hero-image-frame') as HTMLElement;
    
    if (img && frame) {
      /**
       * 解像度上限を計算し、インラインCSSに適用する処理
       */
      const setLimit = () => {
        // 元画像幅とデザイン上限（400px）の小さい方を採用
        const maxLimit = Math.min(img.naturalWidth, 400);
        frame.style.maxWidth = `${maxLimit}px`;
      };

      // 画像ロード完了状態に応じたイベント登録
      if (img.complete) {
        setLimit();
      } else {
        img.addEventListener('load', setLimit);
      }
    }
  }

  // ページ初期ロード時およびViewTransitions遷移時の処理実行登録
  document.addEventListener('astro:page-load', adjustImageMaxSize);
</script>
