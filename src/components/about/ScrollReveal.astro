---
/**
 * ScrollReveal コンポーネント
 * ページに1つ配置するだけで、[data-reveal]属性を持つ全要素に
 * スクロール連動ブラー解除アニメーションが自動適用される
 *
 * 使用方法:
 *   要素に data-reveal 属性を付与するだけで対象となる
 *   data-reveal-delay="200" で遅延ms指定が可能（0〜1000）
 */
---

<style is:global>
  /**
   * スクロールアニメーション初期状態
   * data-reveal属性を持つ要素はデフォルトで非表示・ぼかし状態
   */
  [data-reveal] {
    opacity: 0;
    filter: blur(12px);
    transform: translateY(16px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      filter 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /**
   * IntersectionObserverによるis-revealedクラス付与後の状態
   * ぼかし・透明・オフセットをすべて解除する
   */
  [data-reveal].is-revealed {
    opacity: 1;
    filter: blur(0px);
    transform: translateY(0);
  }
</style>

<script>
  /**
   * スクロール連動ブラー解除アニメーション制御
   *
   * [設計意図]
   * IntersectionObserver で [data-reveal] 属性の要素を監視し、
   * ビューポートに入ったタイミングで .is-revealed クラスを付与する。
   * CSS transition によりブラーと透明度が滑らかに解除される。
   * ViewTransitionsとの競合を防ぐため astro:page-load で毎回再初期化する。
   */
  function initScrollReveal(): void {
    // 監視対象要素の取得処理
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');

    if (targets.length === 0) return;

    // IntersectionObserverのコールバック処理
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          // data-reveal-delay属性による遅延ms取得処理
          const delay = parseInt(el.dataset.revealDelay ?? '0', 10);

          // 遅延後にis-revealedクラスを付与してアニメーション開始
          setTimeout(() => {
            el.classList.add('is-revealed');
          }, delay);

          // 一度表示したら監視を解除して不要な処理を防止
          observer.unobserve(el);
        });
      },
      {
        // 要素の20%がビューポートに入った時点でトリガー
        threshold: 0.2,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    // 全ターゲット要素の監視登録処理
    targets.forEach((el) => observer.observe(el));
  }

  // 初回ロード・ViewTransitions遷移後の再初期化処理
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
