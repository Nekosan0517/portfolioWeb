---
/**
 * ScrollReveal コンポーネント
 * ページに1つ配置するだけで、[data-reveal]属性を持つ全要素に
 * スクロール連動ブラー解除アニメーションが自動適用される
 *
 * 使用方法:
 *   要素に data-reveal 属性を付与するだけで対象となる
 *   data-reveal-delay="200" で遅延ms指定が可能（0〜1000）
 */
---


<script>
  /**
   * スクロール連動ブラー解除アニメーション制御
   *
   * [設計意図]
   * IntersectionObserver で [data-reveal] 属性の要素を監視し、
   * ビューポートに入ったタイミングで .is-revealed クラスを付与する。
   * CSS transition によりブラーと透明度が滑らかに解除される。
   *
   * [ViewTransitionsとの競合回避]
   * astro:page-load はViewTransitionアニメーション(700ms)完了後に発火するため、
   * VT実行中にblurアニメーションが競合する問題がない。
   * BaseLayoutでis-transitioningクラスを使いVT中はtransitionを無効化する二重安全網も備える。
   */
  function initScrollReveal(): void {
    // 監視対象要素の取得処理
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');

    if (targets.length === 0) return;

    // IntersectionObserverのコールバック処理
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          // data-reveal-delay属性による遅延ms取得処理
          const delay = parseInt(el.dataset.revealDelay ?? '0', 10);

          // 遅延後にis-revealedクラスを付与してアニメーション開始
          setTimeout(() => {
            el.classList.add('is-revealed');
          }, delay);

          // 一度表示したら監視を解除して不要な処理を防止
          observer.unobserve(el);
        });
      },
      {
        // 要素の20%がビューポートに入った時点でトリガー
        threshold: 0.2,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    // 全ターゲット要素の監視登録処理
    targets.forEach((el) => observer.observe(el));
  }

  // ページ遷移後の初期化処理（初回ロード・SPA遷移どちらにも対応）
  // VTのfade-inアニメーション完了後に発火するastro:page-loadを使用することで競合を回避
  document.addEventListener('astro:page-load', () => {
    // スクロール連動ブラー解除アニメーションの初期化処理
    initScrollReveal();
  });
</script>
