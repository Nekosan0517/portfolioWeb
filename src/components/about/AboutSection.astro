---
/**
 * AboutSection コンポーネント
 * profile.json の about データを受け取り、自己紹介テキストとプロフィール画像を表示する
 * デスクトップ: 左テキスト + 右画像の2カラム
 * モバイル: 縦積みレイアウト
 */

interface Props {
  /** Aboutセクション表示データ（profile.json の about フィールド） */
  about: {
    profileImage: string;
    paragraphs: string[];
  };
}

const { about } = Astro.props;
---

<section class="about-section" aria-label="自己紹介">
  <!-- セクション見出しライン -->
  <div class="section-header" data-reveal>
    <span class="section-label">About</span>
    <span class="section-line" aria-hidden="true"></span>
  </div>

  <div class="about-content">
    <!-- テキストコンテンツ -->
    <div class="about-text">
      {about.paragraphs.map((paragraph, i) => (
        <p
          class="about-paragraph"
          data-reveal
          data-reveal-delay={String(i * 120)}
        >
          {paragraph}
        </p>
      ))}
    </div>
  </div>
</section>

<style>
  /* Aboutセクション全体 */
  .about-section {
    padding: 5rem 0;
    border-top: 1px solid var(--card-border);
  }

  /* セクション見出し（ラベル + 装飾ライン） */
  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  /* セクションラベルテキスト */
  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--text-subtle);
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }

  /* セクション区切りライン */
  .section-line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--card-border);
  }

  /* コンテンツ領域（最大幅制限） */
  .about-content {
    max-width: 800px;
  }

  /* テキストカラム */
  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  /* 自己紹介段落 */
  .about-paragraph {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    font-weight: 400;
    line-height: 2;
    color: var(--text-muted);
    margin: 0;
    font-family: 'Noto Sans JP', 'Inter', sans-serif;
  }
</style>
