---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
	side: 'left' | 'right';
	id: string;
}

const { side, id } = Astro.props;

/**
 * 1. データを取得
 */
const allWorks: CollectionEntry<'works'>[] = await getCollection('works');

/**
 * 2. ソート処理
 */
const sortedWorks = allWorks.sort((a, b) => a.data.order - b.data.order);

/**
 * 3. 配置と表示/非表示のロジック
 * - translate-x-full: 画面の右/左外に配置
 * - [.is-side-open_&]:translate-x-0: bodyにクラスがついた時だけ画面内に戻す
 */
const sideClasses = side === 'left' 
	? 'left-0 -translate-x-full [.is-left-open_&]:translate-x-0 border-r border-white/10' 
	: 'right-0 translate-x-full [.is-right-open_&]:translate-x-0 border-l border-white/10';
---

<aside
	id={id}
	class:list={[
		"fixed top-0 z-50 h-full w-80 max-w-[80vw] transition-transform duration-700 ease-in-out",
		"bg-black/60 backdrop-blur-3xl shadow-2xl",
		sideClasses
	]}
	aria-hidden="true"
>
	<div class="flex flex-col h-full p-8">
		<div class="mb-12">
			<h2 class="text-xs font-bold tracking-[0.2em] text-white/40 uppercase">
				{side === 'left' ? 'Navigation' : 'Works Index'}
			</h2>
			<p class="mt-2 text-sm text-white/20">
				{side === 'left' ? 'Select category' : 'Explore my creations'}
			</p>
		</div>

		<nav class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
			<ul class="space-y-6">
				{side === 'left' ? (
					['GAME', 'TOOL', 'VIDEO'].map((cat) => (
						<li class="group">
							<a href={`/category/${cat.toLowerCase()}`} class="text-2xl font-light text-white/60 group-hover:text-white transition-all duration-300 flex items-center">
								<span class="w-0 h-[1px] bg-white group-hover:w-8 transition-all duration-500 mr-0 group-hover:mr-4"></span>
								{cat}
							</a>
						</li>
					))
				) : (
					sortedWorks.map((work) => (
						<li class="group">
							<a href={`/works/${work.id}`} class="block">
								<span class="text-xs text-white/30 block mb-1 uppercase tracking-tighter">
									{work.data.category}
								</span>
								<div class="text-xl font-light text-white/60 group-hover:text-white transition-all duration-300 flex items-center">
									<span class="w-0 h-[1px] bg-white group-hover:w-4 transition-all duration-500 mr-0 group-hover:mr-3"></span>
									{work.data.title}
								</div>
							</a>
						</li>
					))
				)}
			</ul>
		</nav>

		<div class="mt-auto pt-6 border-t border-white/5">
			<button 
				class="text-xs text-white/30 hover:text-white transition-colors uppercase tracking-widest" 
				onclick={`document.body.classList.remove('is-${side}-open', 'is-drawer-open')`}
			>
				[ Close ]
			</button>
		</div>
	</div>
</aside>

<style>
	.custom-scrollbar::-webkit-scrollbar { width: 2px; }
	.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); }
</style>