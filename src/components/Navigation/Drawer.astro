---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../../constants/categories';

interface Props {
	side: 'left' | 'right';
	id: string;
	activeCategory?: string;
}

const { side, id, activeCategory } = Astro.props;

/**
 * 1. データを取得
 */
const allWorks: CollectionEntry<'works'>[] = await getCollection('works');
const categoriesList = Object.values(CATEGORIES);

/**
 * 2. ソート処理
 */
const sortedWorks = allWorks.sort((a, b) => b.data.date.localeCompare(a.data.date));

// activeCategory が指定されており、かつ右側ドロワーの場合はフィルタリングを行う
const displayWorks = (side === 'right' && activeCategory)
	? sortedWorks.filter(work => work.data.category === activeCategory)
	: sortedWorks;

/**
 * 3. 配置と表示/非表示のロジック
 * - translate-x-full: 画面の右/左外に配置
 * - [.is-side-open_&]:translate-x-0: bodyにクラスがついた時だけ画面内に戻す
 */
const sideClasses = side === 'left' 
	? 'left-0 -translate-x-full [.is-left-open_&]:translate-x-0 border-r-2 border-[#967661]/35' 
	: 'right-0 translate-x-full [.is-right-open_&]:translate-x-0 border-l-2 border-[#967661]/35';
---

<aside
	id={id}
	class:list={[
		"fixed top-0 z-50 h-full w-80 max-w-[80vw] transition-transform duration-700 ease-in-out",
		"bg-[var(--drawer-bg)] backdrop-blur-3xl shadow-2xl",
		sideClasses
	]}
	aria-hidden="true"
>
	<div class="flex flex-col h-full p-8">
		<div class="mb-12">
			<h2 class="text-xs font-bold tracking-[0.2em] text-[var(--text-subtle)] uppercase">
				{side === 'left' ? 'Navigation' : 'Works Index'}
			</h2>
			<p class="mt-2 text-sm text-[var(--text-subtle)]/70">
				{side === 'left' ? 'Select category' : 'Explore my creations'}
			</p>
		</div>

		<nav class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
			<ul class="space-y-6">
				{side === 'left' ? (
					categoriesList.map((cat) => (
						<li class="group">
							<a href={`/category/${cat.id}`} class="text-2xl font-light text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-all duration-300 flex items-center">
								<span class="w-0 h-[2px] bg-[#B36C34] group-hover:w-8 transition-all duration-500 mr-0 group-hover:mr-4"></span>
								{cat.label}
							</a>
						</li>
					))
				) : (
					displayWorks.map((work) => (
						<li class="group">
							<a href={`/works/${work.id}`} class="block">
								<span class="text-xs text-[var(--text-subtle)] block mb-1 uppercase tracking-tighter">
									{work.data.category}
								</span>
								<div class="text-xl font-light text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-all duration-300 flex items-center">
									<span class="w-0 h-[2px] bg-[#B36C34] group-hover:w-4 transition-all duration-500 mr-0 group-hover:mr-3"></span>
									{work.data.title}
								</div>
							</a>
						</li>
					))
				)}
			</ul>
		</nav>

		<div class="mt-auto pt-6 border-t border-[var(--card-border)]">
			<button 
				class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors uppercase tracking-widest" 
				onclick={`document.body.classList.remove('is-${side}-open', 'is-drawer-open')`}
			>
				[ Close ]
			</button>
		</div>
	</div>
</aside>

<style>
	.custom-scrollbar::-webkit-scrollbar { width: 2px; }
	.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); }
</style>

<script>
	function setupDrawerLinks() {
		// ドロワー内のリンクで、まだリスナー登録がされていないものを取得
		const links = document.querySelectorAll('aside nav a:not([data-has-transition-listener])');

		links.forEach(link => {
			link.addEventListener('click', (event) => {
				const href = link.getAttribute('href');
				if (!href || href.startsWith('#')) return;

				event.preventDefault();

				// 1. 即座にドロワーを閉じるクラスを解除（CSSによるスライドクローズが開始）し、
				// 同時に画面全体のフェードアウト（700ms）を開始するクラスを付与
				document.body.classList.add('is-fading-out');
				document.body.classList.remove('is-left-open', 'is-right-open', 'is-drawer-open');

				// 2. ドロワーが完全に閉じきり、同時にフェードアウトが完了したタイミング（750ms）で
				// Astroのクライアントサイド遷移を実行する
				setTimeout(() => {
					import('astro:transitions/client').then(({ navigate }) => {
						navigate(href);
					});
				}, 750);
			});

			// 多重登録防止用のフラグを設定
			link.setAttribute('data-has-transition-listener', 'true');
		});
	}

	// 初期化およびスワップ後の再初期化
	setupDrawerLinks();
	document.addEventListener('astro:after-swap', setupDrawerLinks);
</script>