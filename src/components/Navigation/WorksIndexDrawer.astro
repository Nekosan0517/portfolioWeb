---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
	id: string;
	activeCategory?: string;
}

const { id, activeCategory } = Astro.props;

// 全作品データの取得処理
const allWorks: CollectionEntry<"works">[] = await getCollection("works");

// 日付の降順による作品データのソート処理
const sortedWorks = allWorks.sort((a, b) =>
	b.data.date.localeCompare(a.data.date),
);

// アクティブカテゴリによる作品データの絞り込み処理
const displayWorks = activeCategory
	? sortedWorks.filter((work) => work.data.category === activeCategory)
	: sortedWorks;
---

<aside
	id={id}
	class:list={[
		"fixed top-0 z-50 h-full w-80 max-w-[80vw] transition-transform duration-700 ease-in-out",
		"bg-[var(--drawer-bg)] shadow-2xl",
		"right-0 translate-x-full [.is-right-open_&]:translate-x-0 border-l-2 border-[#967661]/35",
	]}
	style="-webkit-backdrop-filter: blur(64px); backdrop-filter: blur(64px); will-change: transform, backdrop-filter; -webkit-backface-visibility: hidden; backface-visibility: hidden;"
	aria-hidden="true"
>
	<div class="flex flex-col h-full p-8">
		<div class="mb-12">
			<h2 class="text-xs font-bold tracking-[0.2em] text-[var(--text-subtle)] uppercase">
				Works Index
			</h2>
			<p class="mt-2 text-sm text-[var(--text-subtle)]/70">
				Explore my creations
			</p>
		</div>

		<nav class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
			<ul class="space-y-6">
				{
					// 作品リスト配列に基づくインデックス項目のレンダリング処理
					displayWorks.map((work) => (
						<li class="group">
							<a href={`/works/${work.id}`} class="block">
								<span class="text-xs text-[var(--text-subtle)]/70 block mb-1 uppercase tracking-tighter">
									{work.data.category}
								</span>
								<div class="text-xl font-light text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-all duration-300 flex items-center">
									<span class="w-0 h-[2px] bg-[#D88C51] group-hover:w-4 transition-all duration-500 mr-0 group-hover:mr-3" />
									{work.data.title}
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="mt-auto pt-6 border-t border-[var(--card-border)]">
			<button
				class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors uppercase tracking-widest"
				onclick="document.body.classList.remove('is-right-open', 'is-drawer-open')"
			>
				[ Close ]
			</button>
		</div>
	</div>
</aside>

<script>
	/**
	 * ドロワー内リンクのトランジション制御処理
	 * 
	 * [非自明ロジックの機能解説]
	 * NavigationDrawer と同様に、Astro の SPA 遷移時のイベントリスナー多重登録の防止、
	 * およびドロワーが閉じるアニメーション (700ms) と同期したスムーズな画面遷移を実現する処理。
	 */
	// リンククリック時の画面遷移処理のセットアップ
	function setupDrawerLinks() {
		// 未登録のドロワー内作品リンク要素の取得処理
		const links = document.querySelectorAll(
			"aside nav a:not([data-has-transition-listener])",
		);

		// 各リンクへのイベントリスナー登録処理
		links.forEach((link) => {
			// クリックイベントのリスナー登録処理
			link.addEventListener("click", (event) => {
				// 遷移先URL属性の取得処理
				const href = link.getAttribute("href");
				if (!href || href.startsWith("#")) return;

				// デフォルト遷移の無効化処理
				event.preventDefault();

				// body へのクラス追加によるフェードアウトアニメーション開始処理
				document.body.classList.add("is-fading-out");
				// ドロワーを閉じるための body からのクラス除去処理
				document.body.classList.remove(
					"is-left-open",
					"is-right-open",
					"is-drawer-open",
				);

				// トランジション完了後の遅延遷移実行処理
				setTimeout(() => {
					// 画面遷移用モジュールのインポートおよび遷移実行処理
					import("astro:transitions/client").then(({ navigate }) => {
						// 遷移先URLへの移動処理
						navigate(href);
					});
				}, 750);
			});

			// 多重登録防止用属性の設定処理
			link.setAttribute("data-has-transition-listener", "true");
		});
	}

	// 初期ロード時のセットアップ実行処理
	setupDrawerLinks();
	// SPAページ遷移後の再初期化イベント監視処理
	document.addEventListener("astro:after-swap", setupDrawerLinks);
</script>
