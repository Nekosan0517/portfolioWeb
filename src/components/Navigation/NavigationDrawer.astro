---
import { CATEGORIES } from "../../constants/categories";

interface Props {
	id: string;
}

const { id } = Astro.props;
// カテゴリ定数オブジェクトの値の配列化処理
const categoriesList = Object.values(CATEGORIES);
---

<aside
	id={id}
	class:list={[
		"fixed top-0 z-50 h-full w-80 max-w-[80vw] transition-transform duration-700 ease-in-out",
		"bg-[var(--drawer-bg)] backdrop-blur-3xl shadow-2xl",
		"left-0 -translate-x-full [.is-left-open_&]:translate-x-0 border-r-2 border-[#967661]/35",
	]}
	aria-hidden="true"
>
	<div class="flex flex-col h-full p-8">
		<div class="mb-12">
			<h2
				class="text-xs font-bold tracking-[0.2em] text-[var(--text-subtle)] uppercase"
			>
				Navigation
			</h2>
			<p class="mt-2 text-sm text-[var(--text-subtle)]/70">
				Select category
			</p>
		</div>

		<nav class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
			<ul class="space-y-6">
				<li class="group">
					<a
						href="/"
						class="text-2xl font-light text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-all duration-300 flex items-center"
					>
						<span
							class="w-0 h-[2px] bg-[#D88C51] group-hover:w-8 transition-all duration-500 mr-0 group-hover:mr-4"
						></span>
						ALL Archive
					</a>
				</li>
				{
					// カテゴリリスト配列に基づくナビゲーション項目のレンダリング処理
					categoriesList.map((cat) => (
						<li class="group">
							<a
								href={`/category/${cat.id}`}
								class="text-2xl font-light text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-all duration-300 flex items-center"
							>
								<span class="w-0 h-[2px] bg-[#D88C51] group-hover:w-8 transition-all duration-500 mr-0 group-hover:mr-4" />
								{cat.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="mt-auto pt-6 border-t border-[var(--card-border)]">
			<button
				class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors uppercase tracking-widest"
				onclick="document.body.classList.remove('is-left-open', 'is-drawer-open')"
			>
				[ Close ]
			</button>
		</div>
	</div>
</aside>

<script>
	/**
	 * ドロワー内リンクのトランジション制御処理
	 * 
	 * [非自明ロジックの機能解説]
	 * 1. Astro の SPA 遷移 (ViewTransitions) 時、ページ遷移後もグローバルなイベントリスナーが
	 *    重複登録されてしまうのを防ぐため、カスタム属性 `data-has-transition-listener` で重複チェック。
	 * 2. リンククリック時、ドロワーが閉じる CSS アニメーション (700ms) と画面のフェードアウト処理が
	 *    同時に開始されるよう、body に `is-fading-out` を付与しつつドロワー開閉用クラスを除去。
	 * 3. アニメーションが完全に完了したタイミング (750ms) で Astro の `navigate` 関数を手動実行し、画面遷移を実装。
	 */
	// リンククリック時の画面遷移処理のセットアップ
	function setupDrawerLinks() {
		// 未登録のドロワー内ナビゲーションリンク要素の取得処理
		const links = document.querySelectorAll(
			"aside nav a:not([data-has-transition-listener])",
		);

		// 各リンクへのイベントリスナー登録処理
		links.forEach((link) => {
			// クリックイベントのリスナー登録処理
			link.addEventListener("click", (event) => {
				// 遷移先URL属性の取得処理
				const href = link.getAttribute("href");
				if (!href || href.startsWith("#")) return;

				// デフォルト遷移の無効化処理
				event.preventDefault();

				// body へのクラス追加によるフェードアウトアニメーション開始処理
				document.body.classList.add("is-fading-out");
				// ドロワーを閉じるための body からのクラス除去処理
				document.body.classList.remove(
					"is-left-open",
					"is-right-open",
					"is-drawer-open",
				);

				// トランジション完了後の遅延遷移実行処理
				setTimeout(() => {
					// 画面遷移用モジュールのインポートおよび遷移実行処理
					import("astro:transitions/client").then(({ navigate }) => {
						// 遷移先URLへの移動処理
						navigate(href);
					});
				}, 750);
			});

			// 多重登録防止用属性の設定処理
			link.setAttribute("data-has-transition-listener", "true");
		});
	}

	// 初期ロード時のセットアップ実行処理
	setupDrawerLinks();
	// SPAページ遷移後の再初期化イベント監視処理
	document.addEventListener("astro:after-swap", setupDrawerLinks);
</script>
