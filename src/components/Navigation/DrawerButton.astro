---
// Propsの定義: どちらの端に置くか、どのIDのドロワーを操作するかを受け取る
interface Props {
	side: 'left' | 'right';
	targetId: string;
}

const { side, targetId } = Astro.props;

// 配置場所を計算（左ならleft:0、右ならright:0）
const positionClass = side === 'left' ? 'left-0 rounded-r-full border-l-0' : 'right-0 rounded-l-full border-r-0';
---

<button
	id={`btn-${side}`}
	data-target={targetId}
	data-side={side}
	class:list={[
		"fixed top-1/2 z-[60] h-24 w-6 -translate-y-1/2 transition-all duration-300",
		"bg-white/5 hover:bg-white/20 backdrop-blur-md border border-white/20",
		"flex items-center justify-center group focus:outline-none focus:ring-2 focus:ring-blue-500/50",
		positionClass
	]}
	aria-label={`Open ${side} menu`}
>
	<svg 
		xmlns="http://www.w3.org/2000/svg" 
		class:list={[
			"w-4 h-4 text-white/50 group-hover:text-white transition-transform duration-300",
			side === 'left' ? "rotate-0 group-hover:translate-x-1" : "rotate-180 group-hover:-translate-x-1"
		]} 
		fill="none" 
		viewBox="0 0 24 24" 
		stroke="currentColor"
	>
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
	</svg>
</button>

<script>
	// クライアント側（ブラウザ）で動くロジック
	function setupDrawerButton() {
		const buttons = document.querySelectorAll('button[data-target]');
		
		buttons.forEach(button => {
			button.addEventListener('click', () => {
				const targetId = button.getAttribute('data-target');
				const side = button.getAttribute('data-side');
				const body = document.body;

				if (side === 'left') {
					body.classList.toggle('is-left-open');
				} else {
					body.classList.toggle('is-right-open');
				}

				// いずれかが開いていれば全体のぼかし用クラスを付与
				const isOpen = body.classList.contains('is-left-open') || body.classList.contains('is-right-open');
				body.classList.toggle('is-drawer-open', isOpen);
			});
		});
	}

	// AstroのView Transitionsに対応するための実行コード
	setupDrawerButton();
	document.addEventListener('astro:after-swap', setupDrawerButton);
</script>