---
// Propsの定義: どちらの端に置くか、どのIDのドロワーを操作するかを受け取る
interface Props {
	side: 'left' | 'right';
	targetId: string;
}

const { side, targetId } = Astro.props;

/**
 * 配置と連動移動のロジック
 * - left-0 / right-0: 初期位置
 * - [.is-left-open_&]:translate-x-80: 左ドロワーが開いた時、右に80(20rem)移動
 * - [.is-right-open_&]:-translate-x-80: 右ドロワーが開いた時、左に80(20rem)移動
 */
const positionClass = side === 'left' 
	? 'left-0 rounded-r-full border-l-0 [.is-left-open_&]:translate-x-80' 
	: 'right-0 rounded-l-full border-r-0 [.is-right-open_&]:-translate-x-80';
---

<button
	id={`btn-${side}`}
	data-target={targetId}
	data-side={side}
	class:list={[
		"fixed top-1/2 z-[60] h-24 w-6 -translate-y-1/2 transition-all duration-700 ease-in-out",
		"bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20",
		"flex items-center justify-center group focus:outline-none",
		positionClass
	]}
	aria-label={`Open ${side} menu`}
>
	<svg 
		xmlns="http://www.w3.org/2000/svg" 
		class:list={[
			"w-4 h-4 text-white/50 group-hover:text-white transition-transform duration-500",
			side === 'left' 
				? "rotate-0 [.is-left-open_&]:rotate-180" 
				: "rotate-180 [.is-right-open_&]:rotate-0"
		]} 
		fill="none" 
		viewBox="0 0 24 24" 
		stroke="currentColor"
	>
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
	</svg>
</button>

<script>
	function setupDrawerButton() {
		// すでにリスナー登録済みのボタン（data-has-listener を持つもの）は対象外にする
		const buttons = document.querySelectorAll('button[data-target]:not([data-has-listener])');
		buttons.forEach(button => {
			button.addEventListener('click', () => {
				const side = button.getAttribute('data-side');
				const body = document.body;

				if (side === 'left') {
					body.classList.toggle('is-left-open');
					// 反対側が開いていたら閉じる（干渉防止）
					body.classList.remove('is-right-open');
				} else {
					body.classList.toggle('is-right-open');
					body.classList.remove('is-left-open');
				}

				const isOpen = body.classList.contains('is-left-open') || body.classList.contains('is-right-open');
				body.classList.toggle('is-drawer-open', isOpen);
			});

			// リスナー登録済みフラグを設定
			button.setAttribute('data-has-listener', 'true');
		});
	}

	setupDrawerButton();
	document.addEventListener('astro:after-swap', setupDrawerButton);
</script>

<!--
自己検証（バグチェック）結果
- 構文エラーの有無: 正常（Astro フロントマターおよびスクリプト構文にエラーなし）
- 多重登録の防止検証: data-has-listener 属性によるフィルター制御を追加し、transition:persist によって維持されたボタンに対して遷移時にクリックイベントが重複して登録されないことを検証
- DOM遷移動作の検証: astro:after-swap で新しく追加されたトリガーボタンが存在する場合にも、正しくイベントがバインドされることを検証
-->