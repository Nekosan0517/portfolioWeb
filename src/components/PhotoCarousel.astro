---
interface Photo {
	url: string;
	caption?: string;
}

interface Props {
	photos: Photo[];
}

const { photos } = Astro.props;
---

<details class="group-accordion border-y border-[#B36C34]/20 py-6">
	<summary class="flex justify-between items-center cursor-pointer list-none select-none text-xs tracking-[0.2em] uppercase text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors py-2">
		<span class="flex items-center gap-2 font-medium">
			[Photos]
		</span>
		<span class="accordion-icon transition-transform duration-300 transform inline-block text-[10px]">
			▼
		</span>
	</summary>
	<div class="accordion-content">
		<div class="pt-6 overflow-hidden">
			<div class="carousel-container relative flex flex-col items-center gap-6 group/carousel">
				<div class="w-full relative flex items-center">
					<button class="carousel-btn prev-btn absolute left-4 z-10 p-3 rounded-full bg-[var(--card-bg)] border border-[#B36C34]/30 text-[var(--text-subtle)] hover:text-[var(--text-main)] hover:border-[#B36C34] opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 transition-opacity duration-300" aria-label="Previous photo">
						&larr;
					</button>
					<div class="carousel-viewport w-full flex gap-6 overflow-x-auto py-2">
						{photos.map((photo, index) => (
							<div class="carousel-item flex-none w-full flex flex-col items-center justify-center">
								<div class="w-full h-[480px] flex items-center justify-center relative">
									<img
										src={photo.url}
										alt={photo.caption || `Photo ${index + 1}`}
										class="max-w-full max-h-full object-contain border border-[#B36C34]/10 rounded-sm shadow-sm bg-[var(--card-bg)]"
										onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
									/>
									<div class="hidden absolute inset-0 flex items-center justify-center text-[var(--text-subtle)]/20 uppercase tracking-[0.3em] text-[10px]">
										Image Sandbox / No Preview
									</div>
								</div>
								{photo.caption && (
									<p class="mt-3 text-xs text-[var(--text-muted)] tracking-wider">
										{photo.caption}
									</p>
								)}
							</div>
						))}
					</div>
					<button class="carousel-btn next-btn absolute right-4 z-10 p-3 rounded-full bg-[var(--card-bg)] border border-[#B36C34]/30 text-[var(--text-subtle)] hover:text-[var(--text-main)] hover:border-[#B36C34] opacity-0 group-hover/carousel:opacity-100 focus:opacity-100 transition-opacity duration-300" aria-label="Next photo">
						&rarr;
					</button>
				</div>

				{photos.length > 1 && (
					<div class="carousel-indicators flex justify-center gap-3 py-2">
						{photos.map((_, index) => (
							<button
								class="indicator-dot"
								data-index={index}
								aria-label={`Go to photo ${index + 1}`}
							/>
						))}
					</div>
				)}
			</div>
		</div>
	</div>
</details>

<script>
	const initAccordionCarousel = () => {
		const accordion = document.querySelector('details.group-accordion') as HTMLDetailsElement;
		if (!accordion) return;

		const summary = accordion.querySelector('summary');
		const content = accordion.querySelector('.accordion-content') as HTMLElement;
		const viewport = accordion.querySelector('.carousel-viewport') as HTMLElement;
		const prevBtn = accordion.querySelector('.prev-btn') as HTMLButtonElement;
		const nextBtn = accordion.querySelector('.next-btn') as HTMLButtonElement;
		const icon = accordion.querySelector('.accordion-icon') as HTMLElement;

		if (!summary || !content || !viewport) return;

		let isAnimating = false;

		// [非自明ロジックの機能解説]
		// AstroのSPA遷移（ViewTransitions）などによりスクリプトが再実行された際、
		// viewport 内に無限スクロール用のクローン要素が二重に挿入されるのを防ぐため、事前に削除します。
		const existingClones = viewport.querySelectorAll('.is-clone');
		existingClones.forEach((clone) => clone.remove());

		const items = Array.from(viewport.querySelectorAll('.carousel-item')) as HTMLElement[];
		const total = items.length;
		const hasCarousel = total > 1;

		let currentIndex = 1;
		let allItems = items;

		const scrollToCurrentIndex = (smooth = false) => {
			if (!hasCarousel) return;
			const targetItem = allItems[currentIndex];
			if (!targetItem) return;
			
			if (smooth) {
				smoothScrollTo(currentIndex, 750);
			} else {
				// [非自明ロジックの機能解説]
				// 初期位置へ瞬時に移動する際、CSSのスクロールスナップ定義 (scroll-snap-type) と
				// JSのスクロール位置設定が競合して位置ズレを起こすのを防ぐため、一時的にスナップを無効化します。
				viewport.style.scrollSnapType = 'none';
				viewport.scrollLeft = targetItem.offsetLeft;
				viewport.style.scrollSnapType = 'x mandatory';
			}
		};

		if (hasCarousel) {
			// [非自明ロジックの機能解説]
			// 無限ループカルーセルを実現するため、最初の要素を末尾の後に、最後の要素を先頭の前にそれぞれクローン挿入します。
			const firstClone = items[0].cloneNode(true) as HTMLElement;
			const lastClone = items[total - 1].cloneNode(true) as HTMLElement;
			firstClone.classList.add('is-clone');
			lastClone.classList.add('is-clone');

			viewport.insertBefore(lastClone, items[0]);
			viewport.appendChild(firstClone);

			allItems = Array.from(viewport.querySelectorAll('.carousel-item')) as HTMLElement[];
		}

		// アコーディオン開閉制御とアニメーション終了のハンドリング
		summary.addEventListener('click', (e) => {
			e.preventDefault();
			if (isAnimating) return;

			isAnimating = true;

			if (accordion.hasAttribute('open')) {
				accordion.classList.remove('is-open');
				if (icon) icon.style.transform = 'rotate(0deg)';
				
				const onTransitionEnd = (event: TransitionEvent) => {
					if (event.propertyName === 'grid-template-rows') {
						accordion.removeAttribute('open');
						isAnimating = false;
						content.removeEventListener('transitionend', onTransitionEnd);
					}
				};
				content.addEventListener('transitionend', onTransitionEnd);
			} else {
				accordion.setAttribute('open', 'true');
				if (icon) icon.style.transform = 'rotate(180deg)';
				
				requestAnimationFrame(() => {
					requestAnimationFrame(() => {
						accordion.classList.add('is-open');
					});
				});

				const onTransitionEnd = (event: TransitionEvent) => {
					if (event.propertyName === 'grid-template-rows') {
						isAnimating = false;
						content.removeEventListener('transitionend', onTransitionEnd);
						
						if (hasCarousel) {
							scrollToCurrentIndex(false);
							updateState();
						}
					}
				};
				content.addEventListener('transitionend', onTransitionEnd);
			}
		});

		if (hasCarousel && prevBtn && nextBtn) {
			const dots = accordion.querySelectorAll('.indicator-dot');

			if (dots.length <= 1) {
				prevBtn.style.display = 'none';
				nextBtn.style.display = 'none';
			}

			let isScrolling = false;

			// [非自明ロジックの機能解説]
			// CSSの scroll-snap-type が有効なままだと、JSによるなめらかなイージングスクロール中に
			// 挙動がカクついてしまうため、移動中はスナップを無効化 (none) とし、完了後に復元します。
			const smoothScrollTo = (targetIndex: number, duration: number) => {
				if (isScrolling) return;
				isScrolling = true;

				viewport.style.scrollSnapType = 'none';

				const startLeft = viewport.scrollLeft;
				const targetItem = allItems[targetIndex];
				if (!targetItem) {
					isScrolling = false;
					viewport.style.scrollSnapType = 'x mandatory';
					return;
				}

				const targetLeft = targetItem.offsetLeft;
				const change = targetLeft - startLeft;
				const startTime = performance.now();

				const easeInOutQuad = (t: number) => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

				const animateScroll = (currentTime: number) => {
					const elapsed = currentTime - startTime;
					const progress = Math.min(elapsed / duration, 1);
					
					viewport.scrollLeft = startLeft + change * easeInOutQuad(progress);

					if (progress < 1) {
						requestAnimationFrame(animateScroll);
					} else {
						viewport.scrollLeft = targetLeft;
						currentIndex = targetIndex;
						
						handleLoopWrap();
						
						viewport.style.scrollSnapType = 'x mandatory';
						isScrolling = false;
						updateState();
					}
				};

				requestAnimationFrame(animateScroll);
			};

			// [非自明ロジックの機能解説]
			// インデックスがクローン要素（両端）に到達した瞬間、スクロールアニメーションなしで
			// 反対側の本物スライドへ位置をジャンプさせ、シームレスな無限ループを実現します。
			const handleLoopWrap = () => {
				if (currentIndex === 0) {
					currentIndex = total;
					viewport.scrollLeft = allItems[currentIndex].offsetLeft;
				} else if (currentIndex === total + 1) {
					currentIndex = 1;
					viewport.scrollLeft = allItems[currentIndex].offsetLeft;
				}
			};

			const updateState = () => {
				const scrollLeft = viewport.scrollLeft;
				
				let closestIndex = currentIndex;
				let minDiff = Infinity;
				allItems.forEach((item, idx) => {
					const diff = Math.abs(item.offsetLeft - scrollLeft);
					if (diff < minDiff) {
						minDiff = diff;
						closestIndex = idx;
					}
				});

				let realIndex = 0;
				if (closestIndex === 0) {
					realIndex = total - 1;
				} else if (closestIndex === total + 1) {
					realIndex = 0;
				} else {
					realIndex = closestIndex - 1;
				}

				dots.forEach((dot, idx) => {
					if (idx === realIndex) {
						dot.classList.add('is-active');
					} else {
						dot.classList.remove('is-active');
					}
				});
			};

			const handleScrollEnd = () => {
				if (isScrolling) return;

				const scrollLeft = viewport.scrollLeft;
				let closestIndex = currentIndex;
				let minDiff = Infinity;
				allItems.forEach((item, idx) => {
					const diff = Math.abs(item.offsetLeft - scrollLeft);
					if (diff < minDiff) {
						minDiff = diff;
						closestIndex = idx;
					}
				});

				currentIndex = closestIndex;

				// 手動スクロール（スワイプ）でクローン位置に入った場合もループを処理
				if (currentIndex === 0) {
					currentIndex = total;
					viewport.scrollLeft = allItems[currentIndex].offsetLeft;
				} else if (currentIndex === total + 1) {
					currentIndex = 1;
					viewport.scrollLeft = allItems[currentIndex].offsetLeft;
				}

				updateState();
			};

			prevBtn.addEventListener('click', () => {
				if (isScrolling) return;
				smoothScrollTo(currentIndex - 1, 750);
			});

			nextBtn.addEventListener('click', () => {
				if (isScrolling) return;
				smoothScrollTo(currentIndex + 1, 750);
			});

			dots.forEach((dot) => {
				dot.addEventListener('click', () => {
					if (isScrolling) return;
					const index = parseInt(dot.getAttribute('data-index') || '0');
					smoothScrollTo(index + 1, 750);
				});
			});

			let scrollTimeout: number;
			viewport.addEventListener('scroll', () => {
				updateState();
				if (isScrolling) return;

				clearTimeout(scrollTimeout);
				scrollTimeout = window.setTimeout(handleScrollEnd, 150);
			}, { passive: true });

			viewport.addEventListener('scrollend', handleScrollEnd);

			if (accordion.hasAttribute('open')) {
				scrollToCurrentIndex(false);
				updateState();
			}
			
			const resizeObserver = new ResizeObserver(() => {
				if (!isScrolling) {
					viewport.style.scrollSnapType = 'none';
					viewport.scrollLeft = allItems[currentIndex].offsetLeft;
					viewport.style.scrollSnapType = 'x mandatory';
					updateState();
				}
			});
			resizeObserver.observe(viewport);
		} else {
			if (prevBtn) prevBtn.style.display = 'none';
			if (nextBtn) nextBtn.style.display = 'none';
		}
	};

	document.addEventListener('DOMContentLoaded', initAccordionCarousel);
	document.addEventListener('astro:page-load', initAccordionCarousel);
</script>

<style>
	.carousel-viewport {
		-ms-overflow-style: none;
		scrollbar-width: none;
		scroll-snap-type: x mandatory;
	}
	.carousel-viewport::-webkit-scrollbar {
		display: none;
	}

	.carousel-item {
		scroll-snap-align: center;
	}

	.accordion-content {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1);
	}
	
	details.is-open .accordion-content {
		grid-template-rows: 1fr;
	}
	
	details.group-accordion summary::-webkit-details-marker {
		display: none;
	}
	details.group-accordion summary {
		list-style: none;
	}

	.carousel-indicators {
		padding: 8px 0;
	}

	.indicator-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		cursor: pointer;
		outline: none;
		border: 1px solid rgba(179, 108, 52, 0.4);
		background-color: rgba(223, 219, 210, 0.2);
		padding: 0;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: block;
	}

	.indicator-dot:hover {
		border-color: #B36C34;
		background-color: rgba(179, 108, 52, 0.15);
	}

	.indicator-dot.is-active {
		background-color: #B36C34;
		border-color: #B36C34;
		transform: scale(1.25);
	}
</style>
