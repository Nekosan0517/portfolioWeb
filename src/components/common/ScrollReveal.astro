---
/**
 * ScrollReveal コンポーネント
 * ページに1つ配置することで、[data-reveal]属性を持つ全要素に
 * スクロール連動ブラー解除アニメーションを自動適用する
 */
---

<script>
  // 監視対象要素にスクロール連動アニメーションを設定する処理
  function initScrollReveal(): void {
    const targets = document.querySelectorAll<HTMLElement>('[data-reveal]');

    if (targets.length === 0) return;

    // 交差検知時のコールバック処理
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.revealDelay ?? '0', 10);

          // 指定遅延時間後にクラスを付与する処理
          setTimeout(() => {
            el.classList.add('is-revealed');
          }, delay);

          // 監視の解除処理
          observer.unobserve(el);
        });
      },
      {
        threshold: 0.2,
        rootMargin: '0px 0px -40px 0px',
      }
    );

    // 各要素の監視開始処理
    targets.forEach((el) => observer.observe(el));
  }

  // 遷移中の状態を管理するイベントリスナーの設定処理
  function setupTransitionHandler(): void {
    // 遷移準備開始時の処理
    document.addEventListener('astro:before-preparation', () => {
      document.body.classList.add('is-transitioning');
    });

    // DOMスワップ直後の処理
    document.addEventListener('astro:after-swap', () => {
      // 700msのフェードアニメーション完了後に遷移中フラグを除去する処理
      setTimeout(() => {
        document.body.classList.remove('is-transitioning');
      }, 700);
    });

    // ページロード完了時の処理
    document.addEventListener('astro:page-load', () => {
      // フェードアウト状態クラスの除去処理
      document.body.classList.remove('is-fading-out');
      // アニメーション初期化の実行処理
      initScrollReveal();
    });
  }

  // ハンドラ設定の実行処理
  setupTransitionHandler();
</script>

<style is:global>
  /* スクロールアニメーション初期状態
     data-reveal属性を持つ要素はデフォルトで非表示・ぼかし状態 */
  [data-reveal] {
    opacity: 0;
    filter: blur(12px);
    transform: translateY(16px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      filter 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* IntersectionObserverによるis-revealedクラス付与後の状態
     ぼかし・透明・オフセットをすべて解除する */
  [data-reveal].is-revealed {
    opacity: 1;
    filter: blur(0px);
    transform: translateY(0);
  }

  /* ViewTransition実行中はdata-revealのtransitionを無効化
     VTのblurアニメーションとの競合によるちらつきを防止 */
  .is-transitioning [data-reveal],
  .is-transitioning [data-reveal].is-revealed {
    transition: none;
  }
</style>
