---
// 背景コンポーネント：物理演算＋色彩・ゆらぎアップデート版
---

<canvas id="bg-canvas" class="fixed inset-0 -z-10 bg-[var(--bg-canvas)]" transition:persist></canvas>

<script>
    // 淡い差し色のパレット定義
    // 原色を避け、透明度を調整した「おしゃれな淡い色」を採用
    const COLOR_PALETTE = [
        "rgba(0, 0, 0, 0.08)",       // 薄い黒
        "rgba(255, 107, 0, 0.22)",   // 鮮やかなオレンジ
        "rgba(0, 0, 0, 0.04)",       // ごく薄い黒
        "rgba(255, 140, 40, 0.14)",  // 淡いオレンジ
        "rgba(100, 100, 110, 0.1)",  // 薄いグレー
    ];

    // 多重初期化およびリーク防止のためのライフサイクル管理変数
    let animationFrameId: number | null = null;
    let resizeListener: (() => void) | null = null;

    class Particle {
        private canvas: HTMLCanvasElement;
        private x: number = 0;
        private y: number = 0;
        private size: number = 0;
        private vx: number = 0;
        private vy: number = 0;
        private baseVx: number = 0;
        private baseVy: number = 0;
        private friction: number = 0.98;
        private color: string = "";

        // 単調さを消すための「ゆらぎ」パラメータ
        private wiggles: number = Math.random() * Math.PI * 2;
        private wiggleSpeed: number = Math.random() * 0.02;

        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.init();
        }

        init(): void {
            this.x = Math.random() * this.canvas.width;
            this.y = Math.random() * this.canvas.height;
            this.size = Math.random() * 1.8 + 0.3; // サイズのバリエーションを拡大

            // 初速にランダムな方向性を持たせる
            const angle = Math.random() * Math.PI * 2;
            const force = Math.random() * 0.3;
            this.vx = Math.cos(angle) * force;
            this.vy = Math.sin(angle) * force;

            this.baseVx = this.vx;
            this.baseVy = this.vy;

            // パレットからランダムに色を割り当て
            this.color =
                COLOR_PALETTE[Math.floor(Math.random() * COLOR_PALETTE.length)];
        }

        update(scrollDelta: number, windForce: number): void {
            // スクロールと風の影響を適用
            this.vy += scrollDelta * 0.03;
            this.vx += windForce;

            // ゆらぎ（蛇行するような動き）を追加して単調さを排除
            this.wiggles += this.wiggleSpeed;
            this.vx += Math.sin(this.wiggles) * 0.05;
            this.vy += Math.cos(this.wiggles) * 0.02;

            // 摩擦と基底速度への復帰
            this.vx =
                this.vx * this.friction + this.baseVx * (1 - this.friction);
            this.vy =
                this.vy * this.friction + this.baseVy * (1 - this.friction);

            this.x += this.vx;
            this.y += this.vy;

            // 画面端のループ処理
            if (this.x > this.canvas.width) this.x = 0;
            if (this.x < 0) this.x = this.canvas.width;
            if (this.y > this.canvas.height) this.y = 0;
            if (this.y < 0) this.y = this.canvas.height;
        }

        draw(ctx: CanvasRenderingContext2D): void {
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function initCanvas(): void {
        // 1. 以前のループやリスナーが存在すれば完全に破棄する（クリーンアップ）
        if (animationFrameId !== null) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
        }
        if (resizeListener !== null) {
            window.removeEventListener("resize", resizeListener);
            resizeListener = null;
        }

        const canvas = document.getElementById(
            "bg-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let particles: Particle[] = [];
        let lastScrollY = window.scrollY;
        let windForce = 0;
        let wasLeftOpen = false;
        let wasRightOpen = false;

        const resize = (): void => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        };

        const createParticles = (): void => {
            particles = [];
            // 密度を調整（画面面積に応じて粒子数を決定）
            const count = Math.floor((canvas.width * canvas.height) / 8000);
            for (let i = 0; i < count; i++) {
                particles.push(new Particle(canvas));
            }
        };

        const animate = (): void => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            const currentScrollY = window.scrollY;
            const scrollDelta = (currentScrollY - lastScrollY) * 0.1;
            lastScrollY = currentScrollY;

            const isLeftOpen = document.body.classList.contains("is-left-open");
            const isRightOpen =
                document.body.classList.contains("is-right-open");

            // ドロワー開閉時の風の演出
            // 開いた瞬間は大きく動き、閉じた瞬間（引き戻す際）は逆方向に慣性をつける
            if (isLeftOpen && !wasLeftOpen) {
                windForce = 1.5;
            } else if (isRightOpen && !wasRightOpen) {
                windForce = -1.5;
            } else if (!isLeftOpen && wasLeftOpen) {
                windForce = -1.5; // 左ドロワーが閉じる時は左方向（逆向き）への風
            } else if (!isRightOpen && wasRightOpen) {
                windForce = 1.5; // 右ドロワーが閉じる時は右方向（逆向き）への風
            } else {
                windForce *= 0.92;
            }

            wasLeftOpen = isLeftOpen;
            wasRightOpen = isRightOpen;

            particles.forEach((p) => {
                p.update(scrollDelta, windForce);
                p.draw(ctx);
            });

            animationFrameId = requestAnimationFrame(animate);
        };

        // リサイズ時のイベントハンドラを保存して登録
        resizeListener = (): void => {
            resize();
            createParticles();
        };
        window.addEventListener("resize", resizeListener);

        resize();
        createParticles();
        animate();
    }

    // 初回初期化
    initCanvas();
    // ページ遷移（スワップ後）の再セットアップ
    document.addEventListener("astro:after-swap", initCanvas);
</script>

