---
---

<canvas id="bg-canvas" class="fixed inset-0 -z-10 bg-[var(--bg-canvas)]" transition:persist></canvas>

<script>
    const COLOR_PALETTE = [
        "rgba(97, 49, 28, 0.1)",
        "rgba(179, 108, 52, 0.18)",
        "rgba(150, 118, 97, 0.2)",
        "rgba(97, 49, 28, 0.06)",
        "rgba(179, 108, 52, 0.10)",
    ];

    let animationFrameId: number | null = null;
    let resizeListener: (() => void) | null = null;

    class Particle {
        private canvas: HTMLCanvasElement;
        private x: number = 0;
        private y: number = 0;
        private z: number = 0;
        
        private vx: number = 0;
        private vy: number = 0;
        private vz: number = 0;

        private baseVx: number = 0;
        private baseVy: number = 0;
        private baseVz: number = 0;

        private age: number = 0;
        private maxLife: number = 0;

        private size: number = 0;
        private color: string = "";
        private isAccent: boolean = false;

        private wiggles: number = Math.random() * Math.PI * 2;
        private wiggleSpeed: number = Math.random() * 0.02;

        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.init();
        }

        init(isRespawn: boolean = false): void {
            this.x = (Math.random() - 0.5) * this.canvas.width;
            this.y = (Math.random() - 0.5) * this.canvas.height;
            
            if (isRespawn) {
                this.z = -250 + Math.random() * 100;
            } else {
                this.z = (Math.random() - 0.5) * 400;
            }

            const angle = Math.random() * Math.PI * 2;
            const force = Math.random() * 0.25;
            this.baseVx = Math.cos(angle) * force;
            this.baseVy = Math.sin(angle) * force;
            // 穏やかに奥に進むベース速度を持たせる
            this.baseVz = 0.05 + Math.random() * 0.1;

            this.vx = this.baseVx;
            this.vy = this.baseVy;
            this.vz = this.baseVz;

            // 大きすぎる粒子を防ぐため、ベースサイズを全体的に縮小 (0.1 〜 0.6)
            this.size = Math.random() * 0.5 + 0.1;

            this.isAccent = false;
            this.color = COLOR_PALETTE[Math.floor(Math.random() * COLOR_PALETTE.length)];

            // 寿命を 600〜1200 フレーム (約10〜20秒) に設定
            this.age = 0;
            this.maxLife = 600 + Math.random() * 600;
        }

        update(scrollDelta: number, windForce: number): void {
            this.age++;

            // 寿命の残り25%以下になったら、徐々に奥（Z+方向）への推進力を加える
            if (this.age > this.maxLife * 0.75) {
                const fadeFactor = (this.age - this.maxLife * 0.75) / (this.maxLife * 0.25);
                this.vz += fadeFactor * 0.15;
            }

            this.z = Math.max(this.z, -280);

            // 寿命が尽きる、または奥限度（z = 250）に達した場合はリスポーン
            if (this.age >= this.maxLife || this.z >= 250) {
                this.init(true);
                return;
            }

            this.vx += windForce * (0.8 + Math.random() * 0.4);
            this.vz += windForce * (Math.random() - 0.5) * 0.15;

            this.vy += scrollDelta * 0.04;

            this.wiggles += this.wiggleSpeed;
            this.vx += Math.sin(this.wiggles) * 0.05;
            this.vy += Math.cos(this.wiggles) * 0.02;

            const k = 0.04;
            this.vx = this.vx * (1 - k) + this.baseVx * k;
            this.vy = this.vy * (1 - k) + this.baseVy * k;
            this.vz = this.vz * (1 - k) + this.baseVz * k;

            this.x += this.vx;
            this.y += this.vy;
            this.z += this.vz;

            // 境界ループ処理 (X, Y 軸のみループ、Z 軸は寿命と消滅で管理)
            const borderX = this.canvas.width / 2 + 50;
            const borderY = this.canvas.height / 2 + 50;
            
            if (this.x > borderX) this.x = -borderX;
            if (this.x < -borderX) this.x = borderX;
            if (this.y > borderY) this.y = -borderY;
            if (this.y < -borderY) this.y = borderY;
        }

        draw(ctx: CanvasRenderingContext2D): void {
            const centerX = this.canvas.width / 2;
            const centerY = this.canvas.height / 2;
            const fov = 300;

            const scale = fov / (fov + this.z);
            const cx = centerX + this.x * scale;
            const cy = centerY + this.y * scale;

            if (cx < 0 || cx > this.canvas.width || cy < 0 || cy > this.canvas.height) {
                return;
            }

            // 被写界深度（疑似DoF）の計算
            const zFocus = -50;
            const distToFocus = Math.abs(this.z - zFocus);
            const blurRatio = Math.min(1.0, distToFocus / 250);

            // 大きすぎる粒子を防ぐため、ボケ拡大倍率を最大 2.0 倍に抑制
            const r = Math.max(0.1, this.size * scale * (1.0 + blurRatio * 1.0));
            const focalAlpha = 1.0 - blurRatio * 0.88;

            const baseAlpha = this.isAccent ? 0.65 : 0.55;
            const depthAlpha = Math.max(0.12, Math.min(1.0, (320 - this.z) / 500));
            
            ctx.save();
            ctx.globalAlpha = baseAlpha * depthAlpha * focalAlpha;
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }
    }

    function initCanvas(): void {
        if (animationFrameId !== null) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
        }
        if (resizeListener !== null) {
            window.removeEventListener("resize", resizeListener);
            resizeListener = null;
        }

        const canvas = document.getElementById("bg-canvas") as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let particles: Particle[] = [];
        let lastScrollY = window.scrollY;
        let windForce = 0;
        let wasLeftOpen = false;
        let wasRightOpen = false;

        const resize = (): void => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        };

        const createParticles = (): void => {
            particles = [];
            const count = Math.floor((canvas.width * canvas.height) / 3000);
            for (let i = 0; i < count; i++) {
                particles.push(new Particle(canvas));
            }
        };

        const animate = (): void => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            const currentScrollY = window.scrollY;
            const scrollDelta = (currentScrollY - lastScrollY) * 0.1;
            lastScrollY = currentScrollY;

            const isLeftOpen = document.body.classList.contains("is-left-open");
            const isRightOpen = document.body.classList.contains("is-right-open");

            if (isLeftOpen && !wasLeftOpen) {
                windForce = 2.2;
            } else if (isRightOpen && !wasRightOpen) {
                windForce = -2.2;
            } else if (!isLeftOpen && wasLeftOpen) {
                windForce = -2.2;
            } else if (!isRightOpen && wasRightOpen) {
                windForce = 2.2;
            } else {
                windForce *= 0.93;
            }

            wasLeftOpen = isLeftOpen;
            wasRightOpen = isRightOpen;

            particles.forEach((p) => {
                p.update(scrollDelta, windForce);
                p.draw(ctx);
            });

            animationFrameId = requestAnimationFrame(animate);
        };

        resizeListener = (): void => {
            resize();
            createParticles();
        };
        window.addEventListener("resize", resizeListener);

        resize();
        createParticles();
        animate();
    }

    initCanvas();
    document.addEventListener("astro:after-swap", initCanvas);
</script>
