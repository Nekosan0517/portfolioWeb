---
// 背景コンポーネント（TypeScript対応版）
---

<canvas id="bg-canvas" class="fixed inset-0 -z-10 bg-[#050505]"></canvas>

<script>
    // 粒子の設計図
    class Particle {
        // 【重要】TypeScriptでは、使う変数をあらかじめ宣言（定義）します
        private canvas: HTMLCanvasElement;
        private x: number = 0;
        private y: number = 0;
        private size: number = 0;
        private vx: number = 0;
        private vy: number = 0;
        private baseVx: number = 0;
        private baseVy: number = 0;
        private friction: number = 0.95;

        // 引数 canvas に「HTMLCanvasElement型」であることを明示します
        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.init();
        }

        init(): void {
            this.x = Math.random() * this.canvas.width;
            this.y = Math.random() * this.canvas.height;
            this.size = Math.random() * 1.5 + 0.5;
            this.vx = (Math.random() - 0.5) * 0.2 + 0.1;
            this.vy = (Math.random() - 0.5) * 0.2;
            this.baseVx = this.vx;
            this.baseVy = this.vy;
        }

        update(scrollDelta: number, windForce: number): void {
            this.vy += scrollDelta * 0.05;
            this.vx += windForce;

            this.vx = this.vx * this.friction + this.baseVx * (1 - this.friction);
            this.vy = this.vy * this.friction + this.baseVy * (1 - this.friction);

            this.x += this.vx;
            this.y += this.vy;

            if (this.x > this.canvas.width) this.x = 0;
            if (this.x < 0) this.x = this.canvas.width;
            if (this.y > this.canvas.height) this.y = 0;
            if (this.y < 0) this.y = this.canvas.height;
        }

        draw(ctx: CanvasRenderingContext2D): void {
            ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function initCanvas(): void {
        // 型アサーション（as ...）を使って、取得した要素がCanvasであることを保証します
        const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext('2d');
        if (!ctx) return; // contextが取得できない場合もエラーを防ぐためにチェック

        let particles: Particle[] = []; // Particleの配列であることを明示
        let lastScrollY = window.scrollY;
        let windForce = 0;

        const resize = (): void => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        };

        const createParticles = (): void => {
            particles = [];
            const count = Math.floor((canvas.width * canvas.height) / 10000);
            for (let i = 0; i < count; i++) {
                particles.push(new Particle(canvas));
            }
        };

        const animate = (): void => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const currentScrollY = window.scrollY;
            const scrollDelta = (currentScrollY - lastScrollY) * 0.1;
            lastScrollY = currentScrollY;

            if (document.body.classList.contains('is-left-open')) {
                windForce = 0.5;
            } else if (document.body.classList.contains('is-right-open')) {
                windForce = -0.5;
            } else {
                windForce *= 0.9;
            }

            particles.forEach(p => {
                p.update(scrollDelta, windForce);
                p.draw(ctx);
            });

            requestAnimationFrame(animate);
        };

        window.addEventListener('resize', () => {
            resize();
            createParticles();
        });

        resize();
        createParticles();
        animate();
    }

    initCanvas();
    document.addEventListener('astro:after-swap', initCanvas);
</script>