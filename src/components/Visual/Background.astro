---
// 背景コンポーネント：物理演算＋色彩・ゆらぎアップデート版
---

<canvas id="bg-canvas" class="fixed inset-0 -z-10 bg-[#020205]"></canvas>

<script>
    // 淡い差し色のパレット定義
    // 原色を避け、透明度を調整した「おしゃれな淡い色」を採用
    const COLOR_PALETTE = [
        'rgba(255, 255, 255, 0.15)', // ベースの白
        'rgba(200, 230, 255, 0.25)', // 淡いブルー（清潔感）
        'rgba(255, 210, 210, 0.25)', // 淡いレッド（体温）
        'rgba(255, 250, 200, 0.20)', // 淡いイエロー（光）
        'rgba(220, 255, 220, 0.20)'  // 淡いグリーン（安らぎ）
    ];

    class Particle {
        private canvas: HTMLCanvasElement;
        private x: number = 0;
        private y: number = 0;
        private size: number = 0;
        private vx: number = 0;
        private vy: number = 0;
        private baseVx: number = 0;
        private baseVy: number = 0;
        private friction: number = 0.98;
        private color: string = '';
        
        // 単調さを消すための「ゆらぎ」パラメータ
        private wiggles: number = Math.random() * Math.PI * 2;
        private wiggleSpeed: number = Math.random() * 0.02;

        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.init();
        }

        init(): void {
            this.x = Math.random() * this.canvas.width;
            this.y = Math.random() * this.canvas.height;
            this.size = Math.random() * 1.8 + 0.3; // サイズのバリエーションを拡大
            
            // 初速にランダムな方向性を持たせる
            const angle = Math.random() * Math.PI * 2;
            const force = Math.random() * 0.3;
            this.vx = Math.cos(angle) * force;
            this.vy = Math.sin(angle) * force;
            
            this.baseVx = this.vx;
            this.baseVy = this.vy;
            
            // パレットからランダムに色を割り当て
            this.color = COLOR_PALETTE[Math.floor(Math.random() * COLOR_PALETTE.length)];
        }

        update(scrollDelta: number, windForce: number): void {
            // スクロールと風の影響を適用
            this.vy += scrollDelta * 0.03;
            this.vx += windForce;

            // ゆらぎ（蛇行するような動き）を追加して単調さを排除
            this.wiggles += this.wiggleSpeed;
            this.vx += Math.sin(this.wiggles) * 0.05;
            this.vy += Math.cos(this.wiggles) * 0.02;

            // 摩擦と基底速度への復帰
            this.vx = this.vx * this.friction + this.baseVx * (1 - this.friction);
            this.vy = this.vy * this.friction + this.baseVy * (1 - this.friction);

            this.x += this.vx;
            this.y += this.vy;

            // 画面端のループ処理
            if (this.x > this.canvas.width) this.x = 0;
            if (this.x < 0) this.x = this.canvas.width;
            if (this.y > this.canvas.height) this.y = 0;
            if (this.y < 0) this.y = this.canvas.height;
        }

        draw(ctx: CanvasRenderingContext2D): void {
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function initCanvas(): void {
        const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let particles: Particle[] = [];
        let lastScrollY = window.scrollY;
        let windForce = 0;

        const resize = (): void => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        };

        const createParticles = (): void => {
            particles = [];
            // 密度を調整（画面面積に応じて粒子数を決定）
            const count = Math.floor((canvas.width * canvas.height) / 8000);
            for (let i = 0; i < count; i++) {
                particles.push(new Particle(canvas));
            }
        };

        const animate = (): void => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const currentScrollY = window.scrollY;
            const scrollDelta = (currentScrollY - lastScrollY) * 0.1;
            lastScrollY = currentScrollY;

            // ドロワー開閉時の風の演出
            if (document.body.classList.contains('is-left-open')) {
                windForce = 0.4;
            } else if (document.body.classList.contains('is-right-open')) {
                windForce = -0.4;
            } else {
                windForce *= 0.92;
            }

            particles.forEach(p => {
                p.update(scrollDelta, windForce);
                p.draw(ctx);
            });

            requestAnimationFrame(animate);
        };

        window.addEventListener('resize', () => {
            resize();
            createParticles();
        });

        resize();
        createParticles();
        animate();
    }

    initCanvas();
    document.addEventListener('astro:after-swap', initCanvas);
</script>