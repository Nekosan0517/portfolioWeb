---
import NavigationDrawer from "../components/Navigation/NavigationDrawer.astro";
import WorksIndexDrawer from "../components/Navigation/WorksIndexDrawer.astro";
import DrawerTrigger from "../components/Navigation/DrawerButton.astro";
import { ViewTransitions } from "astro:transitions";
import ScrollReveal from "../components/common/ScrollReveal.astro";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	activeCategory?: string;
}

const {
	title = "Takuma Mineta | Portfolio",
	description = "Creative Archive",
	activeCategory,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<!-- Google Fonts: preconnect によるDNS先行解決 -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- フォントロード: Inter / Noto Serif JP / Noto Sans JP -->
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Noto+Serif+JP:wght@200;400&family=Noto+Sans+JP:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<ViewTransitions />
	</head>
	<body class="bg-[var(--bg-color)] text-[var(--text-main)] overflow-x-hidden selection:bg-[#8EA5A5]/30">
		<ScrollReveal />

		<NavigationDrawer id="drawer-left" transition:persist />
		<WorksIndexDrawer
			id="drawer-right"
			activeCategory={activeCategory}
		/>

		<DrawerTrigger side="left" targetId="drawer-left" transition:persist />
		<DrawerTrigger
			side="right"
			targetId="drawer-right"
			transition:persist
		/>

		<main
			class="relative z-10 min-h-screen w-full flex flex-col items-center"
		>
			<div
				class="w-full max-w-screen-xl 2xl:max-w-screen-2xl px-6 py-24 md:px-12 lg:px-24 flex flex-col items-center"
			>
				<div class="w-full">
					<slot />
				</div>
			</div>
		</main>

		<script>
			/**
			 * ドロワーおよびトランジションのグローバル状態管理
			 * 
			 * [設計意図の機能解説]
			 * ドロワーコンポーネント（NavigationDrawer, WorksIndexDrawer）やトリガーボタン（DrawerTrigger）は、
			 * 直接お互いのDOMを相互参照せず、`document.body` の classList (`is-left-open`, `is-right-open`, `is-drawer-open`) を
			 * トグルすることで状態を仲介。各パーツ間の結合度を下げ、カプセル化を向上。
			 */

			// 履歴遷移（ブラウザの戻る・進む）の準備開始時、ドロワーを強制的に閉じて表示崩れを防止。
			// （※ is-fading-out はトランジションのフェードアウトが終了するまで透明度を保つ必要があるため、遷移後にリセット）
			// 履歴遷移の開始イベント監視処理
			document.addEventListener('astro:before-preparation', () => {
				// ドロワー開閉用クラスの除去処理
				document.body.classList.remove('is-left-open', 'is-right-open', 'is-drawer-open');
			});

			// 新しいページのロード完了時、全体のフェードアウト状態クラスを確実にクリア。
			// ページロード完了イベント監視処理
			document.addEventListener('astro:page-load', () => {
				// フェードアウト状態クラスの除去処理
				document.body.classList.remove('is-fading-out');
			});
		</script>

		<style is:global>
			:root {
				color-scheme: light;
			}
			html {
				scroll-behavior: smooth;
			}
			body {
				background-color: var(--bg-canvas);
			}

			/* クリック時に即時開始するフェードアウトアニメーション (ドロワー閉動作の700msと完全同期) */
			.is-fading-out main,
			.is-fading-out aside {
				animation: 700ms cubic-bezier(0.6, 0, 0.2, 1) both fade-out;
				will-change: opacity;
			}

			/* カスタムビュー遷移：旧ページの退場はすでに上記のCSSで完了しているため0msとし、新ページの入場（フェードイン）のみを担当 */
			::view-transition-old(root) {
				animation: 0ms none;
			}
			::view-transition-new(root) {
				animation: 700ms cubic-bezier(0.6, 0, 0.2, 1) both fade-in;
				will-change: opacity;
			}

			@keyframes fade-out {
				from {
					opacity: 1;
				}
				to {
					opacity: 0;
				}
			}

			@keyframes fade-in {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}
		</style>
	</body>
</html>

