---
// 1. 必要なパーツとスタイルのインポート
import Background from '../components/Visual/Background.astro';
import Drawer from '../components/Navigation/Drawer.astro';
import DrawerTrigger from '../components/Navigation/DrawerButton.astro';
import '../styles/global.css'; // Tailwindの設定を読み込む

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Takuma Mineta | Portfolio", 
	description = "Creative Archive" 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-black text-white overflow-x-hidden selection:bg-white/20">
		<Background />

		<Drawer side="left" id="drawer-left" />
		<Drawer side="right" id="drawer-right" />

		<DrawerTrigger side="left" targetId="drawer-left" />
		<DrawerTrigger side="right" targetId="drawer-right" />

		<main class="relative z-10 min-h-screen px-6 py-24 md:px-12 lg:px-24">
			<div class="max-w-6xl mx-auto">
				<slot />
			</div>
		</main>

		<style is:global>
			:root {
				color-scheme: dark;
			}
			html {
				scroll-behavior: smooth;
			}
			body {
				background: radial-gradient(circle at 50% 50%, #0a0a0a 0%, #000000 100%);
			}
		</style>
	</body>
</html>