---
import { ViewTransitions } from 'astro:transitions';
import Background from '../components/Visual/Background.astro';
import Drawer from '../components/Navigation/Drawer.astro';
import DrawerButton from '../components/Navigation/DrawerButton.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Takuma Mineta's Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<ViewTransitions />
	</head>
	<body class="bg-black text-white overflow-x-hidden font-sans">
		
		<Background transition:persist />

		<div id="layout-root" class="relative flex min-h-screen">
			
			<Drawer side="left" id="drawer-left" />

			<main id="main-content" class="relative z-10 flex-grow transition-all duration-700 ease-in-out">
				<div class="mx-auto max-w-5xl px-6 py-20">
					<slot />
				</div>
			</main>

			<Drawer side="right" id="drawer-right" />

			<DrawerButton side="left" targetId="drawer-left" />
			<DrawerButton side="right" targetId="drawer-right" />
		</div>

		<style is:global>
			/* 共通のスクロールバー設定などはここに残す */
			::-webkit-scrollbar { width: 6px; }
			::-webkit-scrollbar-track { background: #000; }
			::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }

			/* ドロワー展開時の状態定義（一元管理） */
			.is-drawer-open #main-content {
				filter: blur(20px) brightness(0.5);
				transform: scale(0.95);
				pointer-events: none;
			}
		</style>
	</body>
</html>