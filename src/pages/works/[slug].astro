---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
// BaseLayouts.astro から BaseLayout.astro への名称変更を反映
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * 1. ページ生成パスの定義
 */
export async function getStaticPaths() {
	// フォルダ名を src/content/works に変更した前提です
	const allWorks: CollectionEntry<'works'>[] = await getCollection('works');
	
	return allWorks.map((entry) => ({
		// 【重要】 type: 'data' では entry.slug ではなく entry.id を使用します
		params: { slug: entry.id },
		props: { entry },
	}));
}

/**
 * 2. 型の定義と受け取り
 */
interface Props {
	entry: CollectionEntry<'works'>;
}

const { entry } = Astro.props;
const { title, description, category, tags, url, thumbnail } = entry.data;
---

<BaseLayout title={`${title} | Works`} activeCategory={category}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-12">
			<div class="flex items-center gap-4 mb-6">
				<span class="text-xs tracking-[0.3em] uppercase text-[var(--text-subtle)] px-3 py-1 border border-orange-500/20">
					{category}
				</span>
				<div class="h-[2px] flex-grow bg-gradient-to-r from-orange-500/40 via-[var(--text-subtle-alpha)] to-transparent"></div>
			</div>
			<h1 class="text-5xl font-extralight tracking-tight text-[var(--text-main)] mb-8 leading-tight">
				{title}
			</h1>
			<p class="text-xl text-[var(--text-muted)] leading-relaxed font-light italic">
				{description}
			</p>
		</header>

		<section class="mb-16 group">
			<div class="aspect-video overflow-hidden bg-[var(--card-bg)] border border-orange-500/20 shadow-sm rounded-sm">
				{thumbnail ? (
					<img 
						src={thumbnail} 
						alt={title} 
						class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-1000"
					/>
				) : (
					<div class="w-full h-full flex items-center justify-center text-[var(--text-subtle)]/10 uppercase tracking-[0.5em]">
						Visual Archive Empty
					</div>
				)}
			</div>
		</section>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
			<div class="md:col-span-2">
				<h2 class="text-sm font-bold text-[var(--text-subtle)] uppercase tracking-widest mb-6 underline decoration-orange-500/30 underline-offset-8">
					Project Overview
				</h2>
				<div class="prose max-w-none text-[var(--text-muted)] leading-loose font-light">
					<p>
						現在は JSON データの description を表示しています。
					</p>
				</div>
			</div>

			<aside class="space-y-12">
				<div>
					<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">Technologies</h2>
					<div class="flex flex-wrap gap-2">
						{tags.map((tag: string) => (
							<span class="text-[10px] text-[var(--text-muted)] px-2 py-1 bg-[var(--button-bg)] border border-orange-500/20">
								{tag}
							</span>
						))}
					</div>
				</div>

				{url && (
					<div>
						<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">External Link</h2>
						<a 
							href={url} 
							target="_blank" 
							rel="noopener noreferrer"
							class="inline-block text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors border-b-2 border-orange-500/40 hover:border-orange-500 pb-1"
						>
							Visit Project →
						</a>
					</div>
				)}
			</aside>
		</div>

		<footer class="mt-24 pt-12 border-t-2 border-orange-500/20">
			<a href="/" class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-all tracking-[0.3em] uppercase">
				← Back to Index
			</a>
		</footer>
	</article>
</BaseLayout>
