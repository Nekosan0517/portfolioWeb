---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * 1. ページ生成パスの定義
 */
export async function getStaticPaths() {
	const allWorks: CollectionEntry<'works'>[] = await getCollection('works');
	
	return allWorks.map((entry) => ({
		// type: 'data' では entry.slug ではなく entry.id を使用
		params: { slug: entry.id },
		props: { entry },
	}));
}

/**
 * 2. 型の定義と受け取り
 */
interface Props {
	entry: CollectionEntry<'works'>;
}

const { entry } = Astro.props;
const { title, description, category, tags, url, thumbnail, date } = entry.data;

// "YYYY-MM" → "YYYY年M月" に整形（先頭ゼロ除去）
const [year, month] = date.split('-');
const displayDate = `${year}年${parseInt(month)}月`;
---

<BaseLayout title={`${title} | Works`} activeCategory={category}>
	<article class="max-w-3xl mx-auto">
		<header class="mb-12">
			<div class="flex items-center gap-4 mb-6">
				<span class="text-xs tracking-[0.3em] uppercase text-[var(--text-subtle)] px-3 py-1 border border-[#B36C34]/20">
					{category}
				</span>
				<div class="h-[2px] flex-grow bg-gradient-to-r from-[#B36C34]/50 via-[var(--text-subtle-alpha)] to-transparent"></div>
			</div>
			<h1 class="text-5xl font-extralight tracking-tight text-[var(--text-main)] mb-8 leading-tight">
				{title}
			</h1>
		</header>

		<section class="mb-16 group">
			<div class="aspect-video overflow-hidden bg-[var(--card-bg)] border border-[#B36C34]/20 shadow-sm rounded-sm">
				{thumbnail ? (
					<img 
						src={thumbnail} 
						alt={title} 
						class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-1000"
					/>
				) : (
					<div class="w-full h-full flex items-center justify-center text-[var(--text-subtle)]/10 uppercase tracking-[0.5em]">
						Visual Archive Empty
					</div>
				)}
			</div>
		</section>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
			<div class="md:col-span-2">
				<h2 class="text-sm font-bold text-[var(--text-subtle)] uppercase tracking-widest mb-6 underline decoration-[#B36C34]/30 underline-offset-8">
					Project Overview
				</h2>
				<div class="prose max-w-none text-[var(--text-muted)] leading-loose font-light">
					<p>
						{description}
					</p>
				</div>
			</div>

			<!-- サイドバー: Date → Tools → External Link の順 -->
			<aside class="space-y-12">
				<div>
					<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">Date</h2>
					<p class="text-sm text-[var(--text-muted)] font-light">{displayDate}</p>
				</div>

				<div>
					<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">Tools</h2>
					<div class="flex flex-wrap gap-2">
						{tags.map((tag: string) => (
							<span class="text-[10px] text-[var(--text-muted)] px-2 py-1 bg-[var(--button-bg)] border border-[#B36C34]/20">
								{tag}
							</span>
						))}
					</div>
				</div>

				{url && (
					<div>
						<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">External Link</h2>
						<a 
							href={url} 
							target="_blank" 
							rel="noopener noreferrer"
							class="inline-block text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors border-b-2 border-[#B36C34]/40 hover:border-[#B36C34] pb-1"
						>
							Visit Project →
						</a>
					</div>
				)}
			</aside>
		</div>

		<footer class="mt-24 pt-12 border-t-2 border-[#B36C34]/20">
			<a href="/" class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-all tracking-[0.3em] uppercase">
				← Back to Index
			</a>
		</footer>
	</article>
</BaseLayout>
