---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import { formatDisplayDate } from '../../utils/date';

/**
 * ページ生成用の動的ルートパス生成処理。
 * Astro の data コレクション形式（JSONデータ）を使用しているため、
 * entry.slug ではなく entry.id を params.slug に指定してビルドエラーを防止。
 */
export async function getStaticPaths() {
	// 全作品データの取得処理
	const allWorks: CollectionEntry<'works'>[] = await getCollection('works');
	
	// コレクションのエントリから動的パラメータ配列へのマッピング処理
	return allWorks.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'works'>;
}

const { entry } = Astro.props;
const { title, descriptions, category, tags, url, thumbnail, date, photos } = entry.data;

// 公開年月文字列のフォーマット変換処理
const displayDate = formatDisplayDate(date);
const displayCategory = category.charAt(0).toUpperCase() + category.slice(1);
---

<BaseLayout title={`${title} | Works`} activeCategory={category}>
	<article class="max-w-3xl mx-auto">
		<div class="mb-8">
			<a href={`/category/${category}`} class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors tracking-[0.25em] uppercase">
				← Back to {displayCategory}
			</a>
		</div>

		<header class="mb-12">
			<div class="flex items-center gap-4 mb-6">
				<span class="text-xs tracking-[0.3em] uppercase text-[var(--text-subtle)] px-3 py-1 border border-[#B36C34]/20">
					{category}
				</span>
				<div class="h-[2px] flex-grow bg-gradient-to-r from-[#B36C34]/50 via-[var(--text-subtle-alpha)] to-transparent"></div>
			</div>
			<h1 class="text-6xl font-extralight tracking-tight text-[var(--text-main)] mb-8 leading-tight">
				{title}
			</h1>
		</header>

		<section class="mb-16 flex justify-center">
			{thumbnail ? (
				<img 
					src={thumbnail} 
					alt={title} 
					class="max-w-full max-h-[600px] object-contain border border-[#B36C34]/20 shadow-sm rounded-sm"
				/>
			) : (
				<div class="aspect-video w-full flex items-center justify-center bg-[var(--card-bg)] border border-[#B36C34]/20 shadow-sm rounded-sm text-[var(--text-subtle)]/10 uppercase tracking-[0.5em]">
					Visual Archive Empty
				</div>
			)}
		</section>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
			<div class="md:col-span-2">
				<h2 class="text-sm font-bold text-[var(--text-subtle)] uppercase tracking-widest mb-6 underline decoration-[#B36C34]/30 underline-offset-8">
					Project Overview
				</h2>
				<div class="prose max-w-none text-xl text-[var(--text-muted)] leading-loose font-light">
					{/* 作品説明の段落配列に基づくレンダリング処理 */}
					{descriptions.map((desc: string) => (
						<p class="mb-6 last:mb-0">
							{desc}
						</p>
					))}
				</div>
			</div>

			<aside class="space-y-12">
				<div>
					<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">Date</h2>
					<p class="text-sm text-[var(--text-muted)] font-light">{displayDate}</p>
				</div>

				<div>
					<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">Tools</h2>
					<div class="flex flex-wrap gap-2">
						{/* ツールタグ配列に基づくリストのレンダリング処理 */}
						{tags.map((tag: string) => (
							<span class="text-[10px] text-[var(--text-muted)] px-2 py-1 bg-[var(--button-bg)] border border-[#B36C34]/20">
								{tag}
							</span>
						))}
					</div>
				</div>

				{url && (
					<div>
						<h2 class="text-[10px] font-bold text-[var(--text-subtle)] uppercase tracking-[0.2em] mb-4">External Link</h2>
						<a 
							href={url} 
							target="_blank" 
							rel="noopener noreferrer"
							class="inline-block text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors border-b-2 border-[#B36C34]/40 hover:border-[#B36C34] pb-1"
						>
							Visit Project →
						</a>
					</div>
				)}
			</aside>
		</div>

		{photos && photos.length > 0 && (
			<section class="mt-16">
				<PhotoCarousel photos={photos} />
			</section>
		)}

		<footer class="mt-24 pt-12 border-t-2 border-[#B36C34]/20">
			<a href="/works" class="text-xs text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors tracking-[0.25em] uppercase">
				← Back to Archive
			</a>
		</footer>
	</article>
</BaseLayout>
