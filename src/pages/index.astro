---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorksGrid from '../components/WorksGrid.astro';

const allWorks: CollectionEntry<'works'>[] = await getCollection('works');
const sortedWorks = allWorks.sort((a, b) => b.data.date.localeCompare(a.data.date));

const title = "Takuma Mineta | Portfolio";
---

<BaseLayout title={title}>
	<header class="mb-24 mt-12">
		<h1 class="text-6xl font-extralight tracking-tighter text-[var(--text-main)] mb-4">
			Creative <span class="font-normal italic">Archive</span>
		</h1>
		<p class="text-xl text-[var(--text-muted)] max-w-md leading-relaxed font-light">
			今までの作品の記録。
		</p>
	</header>

	<WorksGrid works={sortedWorks} />
</BaseLayout>