---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/about/HeroSection.astro';
import AboutSection from '../components/about/AboutSection.astro';
import SkillsSection from '../components/about/SkillsSection.astro';
import ContactSection from '../components/about/ContactSection.astro';

// profile.jsonの読み込み処理
// getEntryで型安全にaboutコレクションからプロフィールデータを取得する
const profileEntry = await getEntry('about', 'profile');
const profile = profileEntry!.data;
---

<BaseLayout title={profile.meta.title} description={profile.meta.description}>
  <!-- ヒーローセクション -->
  <HeroSection hero={profile.hero} profileImage={profile.about.profileImage} />

  <!-- 自己紹介セクション -->
  <AboutSection about={profile.about} />

  <!-- スキルセクション -->
  <SkillsSection skills={profile.skills} />

  <!-- コンタクトセクション -->
  <ContactSection contact={profile.contact} />
</BaseLayout>