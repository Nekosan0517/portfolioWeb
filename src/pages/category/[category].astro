---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorksGrid from '../../components/WorksGrid.astro';
import { CATEGORIES, CATEGORY_KEYS } from '../../constants/categories';
import type { CategoryInfo } from '../../constants/categories';

export async function getStaticPaths() {
	const allWorks = await getCollection('works');
	
	return CATEGORY_KEYS.map((catKey) => {
		const categoryInfo = CATEGORIES[catKey];
		const filteredWorks = allWorks
			.filter((work) => work.data.category === catKey)
			.sort((a, b) => a.data.order - b.data.order);
		
		return {
			params: { category: catKey },
			props: { categoryInfo, works: filteredWorks },
		};
	});
}

interface Props {
	categoryInfo: CategoryInfo;
	works: CollectionEntry<'works'>[];
}

const { categoryInfo, works } = Astro.props;
---

<BaseLayout title={`${categoryInfo.label} | Portfolio`} activeCategory={categoryInfo.id}>
	<header class="mb-24 mt-12 w-full">
		<div class="flex items-center gap-4 mb-6">
			<a href="/" class="text-xs tracking-[0.3em] uppercase text-[var(--text-subtle)] hover:text-[var(--text-main)] transition-colors">
				Archive
			</a>
			<span class="text-[var(--text-subtle)]/40 text-xs">/</span>
			<span class="text-xs tracking-[0.3em] uppercase text-[var(--text-main)]">
				{categoryInfo.label}
			</span>
			<div class="h-[2px] flex-grow bg-gradient-to-r from-orange-500/40 via-[var(--text-subtle-alpha)] to-transparent"></div>
		</div>
		
		<h1 class="text-6xl font-extralight tracking-tighter text-[var(--text-main)] mb-4">
			{categoryInfo.label} <span class="font-normal italic">Works</span>
		</h1>
		<p class="text-[var(--text-muted)] max-w-md leading-relaxed font-light">
			{categoryInfo.description}
		</p>
	</header>

	<WorksGrid works={works} />
</BaseLayout>

